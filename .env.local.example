# Beide Variablen sind OPTIONAL — die App läuft komplett ohne sie.
#
# Sobald du einen Key einträgst und `npm run dev` neu startest, swappt die App
# automatisch auf den echten Service. Kein Code muss angepasst werden.

# Claude API (für echte AI-Reiseziel-Vorschläge statt Mock)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Mapbox (für hübschere Karten-Styles statt OpenStreetMap-Raster)
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
