# Vorlage - hier KEINE echten Werte eintragen.
# Fuer echte Werte: Kopie als backend/.env anlegen (ist in .gitignore).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
PORT=
# Optional: kommagetrennte Liste erlaubter Frontend-Origins (z. B. http://localhost:5173).
# Leer = Origin wird reflektiert (ok fuer lokale Solo-Entwicklung, kein Auth/Cookie-Einsatz).
CORS_ORIGIN=
# Optional: welches Claude-Modell fuer die Empfehlungs-Pipeline genutzt wird.
ANTHROPIC_MODEL=
# Fuer die Bilder-Pipeline (database/seed/fetch_images.js).
# Kostenlosen Key erstellen: https://www.pexels.com/api/
PEXELS_API_KEY=
