# Vorlage - hier KEINE echten Werte eintragen.
# Fuer echte Werte: Kopie als frontend/.env anlegen (ist in .gitignore).

# Supabase-Projekt-URL (unkritisch, aus backend/.env uebernehmen)
VITE_SUPABASE_URL=
# Anon/Public-Key aus Supabase Dashboard -> Project Settings -> API
# (NICHT der service_role-Key! Der Anon-Key ist fuers Frontend gedacht)
VITE_SUPABASE_ANON_KEY=

# Optional: Backend-URL ueberschreiben. Ohne diese Variable wird der
# Backend-Host automatisch vom Hostnamen abgeleitet, ueber den die Seite
# selbst geladen wurde (localhost am Desktop, LAN-IP am iPhone).
VITE_API_URL=
